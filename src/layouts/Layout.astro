---
import Navigation from "../components/Navigation.astro";
import "../styles/global.css";
import { PAGE_THEMES, type PageThemeId } from "../lib/pageThemes";

interface Props {
  title?: string;
  /** Use a predefined page theme (recommended). */
  theme?: PageThemeId;
  /** Legacy: custom bg/text when theme is not used. */
  bgColor?: string;
  textColor?: string;
}

const { title, theme: themeId, bgColor, textColor } = Astro.props as Props;
const theme = themeId ? PAGE_THEMES[themeId] : (bgColor && textColor ? { bg: bgColor, text: textColor, navPillText: textColor } : null);
const hasCustomTheme = !!theme;
const bg = theme?.bg;
const text = theme?.text;
const navPillText = theme?.navPillText ?? text;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>Sunit Shirke {title && `| ${title}`}</title>
    <meta name="description" content="Code, sports, business and design." />

    <!-- Open Graph Metadata -->
    <meta property="og:title" content="Sunit Shirke" />
    <meta
      property="og:description"
      content="Code, sports, business and design."
    />
    <meta property="og:url" content="https://www.sssh.me" />
    <meta property="og:site_name" content="Sunit Shirke" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://www.sssh.me" />

    <!-- Robots Metadata -->
    <meta name="robots" content="index, follow" />
    <meta name="robots" content="max-video-preview:-1" />
    <meta name="robots" content="max-image-preview:large" />
    <meta name="robots" content="max-snippet:-1" />

    <!-- Twitter Metadata -->
    <meta name="twitter:title" content="Sunit Shirke" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@sunitshirke" />

    <!-- Google tag (gtag.js) -->
    <script type="text/partytown" async src="https://www.googletagmanager.com/gtag/js?id=G-6PBDJX00DY"
    ></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-6PBDJX00DY");
    </script>
  </head>
  <body class={`min-h-screen relative ${hasCustomTheme ? 'custom-theme' : ''}`} style={hasCustomTheme ? `background: ${bg}; color: ${text};` : undefined}>
    <div class="relative z-10 max-w-3xl w-full mx-auto px-5 sm:px-8 lg:px-12 py-10 sm:py-14">
      <Navigation
        textColor={hasCustomTheme ? text : undefined}
        accentColor={hasCustomTheme ? text : undefined}
        navPillTextColor={hasCustomTheme ? navPillText : undefined}
        dropdownBg={hasCustomTheme ? bg : undefined}
      />
      <main class="mt-6">
        <slot />
      </main>
    </div>
  </body>
</html>

<script>
  import "../js/keybinds.ts";
</script>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }

  body.custom-theme::before {
    display: none;
  }
</style>