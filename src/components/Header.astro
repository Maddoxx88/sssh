---
import { Image } from 'astro:assets';
import { ArrowUpRight, Building2, Github, Linkedin, Mail, MapPin, Download } from "lucide-react";
import sunitHeaderOfficial from '../assets/sunit-official.png';
---
 
<div class="mb-20 space-y-8">
  <!-- Profile Avatar + Name -->
  <div class="hidden lg:flex gap-10 items-center">
    <div class="relative shrink-0">
      <Image src={sunitHeaderOfficial} alt="Sunit Shirke" class="w-36 h-36 rounded-2xl object-cover shadow-xl ring-1 ring-white/10" />
      <div class="absolute -inset-1 rounded-2xl bg-gradient-to-br from-[#FF4A00]/30 to-transparent -z-10 blur-xl opacity-60" aria-hidden="true" />
    </div>
    <div>
      <h1 class="text-5xl lg:text-6xl 2xl:text-7xl font-bold tracking-tight text-white animate-fade-in font-inter">
        sunit shirke
      </h1>
      <div class="flex flex-col gap-2 mt-4 text-white/70 text-base lg:text-lg font-inter">
        <div class="flex items-center gap-2">
          <MapPin className="w-4 h-4 text-white/50" />
          jersey city, nj
        </div>
        <div class="flex items-center gap-2">
          <Building2 className="w-4 h-4 text-white/50" />
          grad researcher @NJIT
        </div>
      </div>
    </div>
  </div>

  <!-- Tagline -->
  <p class="text-xl sm:text-2xl lg:text-3xl font-inter font-medium text-white/90 leading-snug max-w-2xl animate-fade-in">
    I make <span class="text-[#FF4A00] font-semibold">full-stack</span> products that people <span class="text-[#FF4A00]">love.</span>
  </p>

  <p class="text-base lg:text-lg text-white/80 leading-relaxed max-w-2xl font-inter animate-fade-in-up">
    Most fun developer ever (seriously). I enjoy ux design, operating systems and contributing to OSS. I’m also a Project Supervisor @GDG.
  </p>
  <p class="text-base lg:text-lg text-white/80 leading-relaxed max-w-2xl font-inter animate-fade-in-up">
    Blogging used to be a big part of my life, but has lately taken a back seat. Interested in my
    <a class="text-[#FF4A00] hover:text-[#ff6b2b] transition-colors underline underline-offset-4 decoration-[#FF4A00]/50 hover:decoration-[#FF4A00]" href="https://medium.com/design-bootcamp/heres-why-design-tools-don-t-matter-df7c20f55e96" target="_blank" rel="noopener">published work</a>?
  </p>

  <div class="flex space-x-4">
      <a class="bg-white text-black hover:text-[#fff] transition-colors hover:bg-[#FF4A00] inline-flex font-inter items-center gap-1 px-4 py-2 rounded" href="">Resume<Download className="w-4 h-4" /></a>
    <p class="text-base lg:text-lg text-white/80 leading-relaxed font-inter animate-fade-in-up">
      <a class="text-white hover:text-[#FF4A00] transition-colors underline underline-offset-4 inline-flex items-center gap-1 py-2" href="mailto:sunitshirke88@gmail.com">Hire me <ArrowUpRight className="w-4 h-4" /></a>
    </p>
  </div>

  <div class="flex items-center gap-6 mt-10 animate-fade-in-up font-inter">
    <a class="text-white hover:text-[#FF4A00] transition-colors duration-200" href="https://github.com/Maddoxx88" target="_blank" rel="noopener" aria-label="GitHub"><Github className="w-6 h-6" /></a>
    <a class="text-white hover:text-[#FF4A00] transition-colors duration-200" href="https://linkedin.com/in/sunitshirke" target="_blank" rel="noopener" aria-label="LinkedIn"><Linkedin className="w-6 h-6" /></a>
    <a class="text-white hover:text-[#FF4A00] transition-colors duration-200" href="https://x.com/sunitshirke" target="_blank" rel="noopener" aria-label="X"><svg class="w-6 h-6 inline-block" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
    <a class="text-white hover:text-[#FF4A00] transition-colors duration-200" href="mailto:sunitshirke88@gmail.com" aria-label="Email"><Mail className="w-6 h-6" /></a>
  </div>
</div>


