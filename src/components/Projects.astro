---
import { ArrowUpRight, LayoutGrid, LayoutList } from "lucide-react";

import { projects } from "../data/projects";
---

<main class="animate-fade-in-up">
  <h1 class="text-2xl font-bold mb-8 font-inter text-current">
    <span class="mr-2">|</span>
    projects
  </h1>
  <p class="text-current/80 mb-8 leading-relaxed">
    Here are some of the projects i've worked on. I love building tools and
    exploring new technologies along the way.
  </p>

  <div class="flex items-center gap-2 mb-10 font-inter">
    <span class="text-sm text-current/70">view:</span>
    <div
      id="view-selector"
      class="inline-flex rounded border-2 border-current/60 p-1 bg-current/5"
      role="tablist"
      aria-label="Project view"
    >
      <button
        type="button"
        data-view="cards"
        class="view-option inline-flex items-center rounded px-3 py-1.5 text-sm font-medium transition-colors aria-selected:bg-current text-current/50"
        aria-selected="true"
      >
        <LayoutList className="w-4 h-4" aria-hidden />
      </button>
      <button
        type="button"
        data-view="grid"
        class="view-option inline-flex items-center rounded px-3 py-1.5 text-sm font-medium transition-colors aria-selected:bg-current text-current/50"
        aria-selected="false"
      >
        <LayoutGrid className="w-4 h-4" aria-hidden />
      </button>
    </div>
  </div>

  <div
    id="projects-container"
    data-view="cards"
    class="projects-container font-inter"
  >
    {
      projects.map((project) => {
        return (
          <div class="project-card group border-1 border-current/40 shadow p-6 rounded-lg overflow-hidden flex flex-col sm:flex-row gap-4 sm:gap-6">
            <div class="project-card-content min-w-0 flex-1">
              <a target="_blank" href={project.url}>
                <div class="flex justify-between items-start mb-4">
                  <h2 class="text-2xl font-bold text-current">{project.name}</h2>
                  <ArrowUpRight className="w-6 h-6 text-current/80 shrink-0" />
                </div>
              </a>
              <p class="text-sm text-current/80 mb-4">{project.role}</p>
              <p class="project-description text-current/75 mb-6">{project.description}</p>
              <div class="space-y-6">
                <div>
                  <h3 class="font-semibold mb-2 text-current">technologies</h3>
                  <div class="flex flex-wrap gap-2">
                    {project.tags.map((tag) => {
                      return (
                        <span class="px-2 py-1 bg-current/20 text-current rounded text-xs">
                          {tag}
                        </span>
                      );
                    })}
                  </div>
                </div>
              </div>
            </div>
            <a target="_blank" href={project.url} class="project-card-image flex flex-1 items-center justify-center min-w-0 w-full sm:w-auto sm:min-w-[10rem] min-h-[8rem] sm:min-h-0 rounded-lg bg-current/10 text-current/60 group-hover:text-current/80 transition-colors self-stretch">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-16 h-16" aria-hidden="true">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </a>
          </div>
        );
      })
    }
  </div>
</main>

<style>
  .projects-container[data-view="cards"] {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .projects-container[data-view="grid"] {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .projects-container[data-view="grid"] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .projects-container[data-view="grid"] {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  /* Grid: stack image on top, content below; fixed image height */
  .projects-container[data-view="grid"] .project-card {
    flex-direction: column;
    padding: 0;
  }

  .projects-container[data-view="grid"] .project-card-image {
    order: -1;
    width: 100%;
    min-height: 0;
    height: 7rem;
    flex: none;
    border-radius: 0;
    border-bottom: 1px solid currentColor;
    border-bottom-color: color-mix(in srgb, currentColor 15%, transparent);
  }

  .projects-container[data-view="grid"] .project-card-content {
    padding: 1rem 1.25rem 1.25rem;
    flex: 1;
    min-height: 0;
  }

  .projects-container[data-view="grid"] .project-card .project-description {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .projects-container[data-view="grid"] .project-card h2 {
    font-size: 1.25rem;
    margin-bottom: 0.25rem;
  }

  .projects-container[data-view="grid"] .project-card-image svg {
    width: 2.5rem;
    height: 2.5rem;
  }

  /* Greyed out by default, glow on hover */
  .project-card {
    opacity: 0.88;
    transition: opacity 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease, background-color 0.25s ease;
  }

  .project-card:hover {
    opacity: 1;
    border-color: currentColor;
    background-color: color-mix(in srgb, currentColor 8%, transparent);
    box-shadow: 0 0 0 1px currentColor, 0 0 24px 6px color-mix(in srgb, currentColor 22%, transparent);
  }
</style>

<script>
  const container = document.getElementById("projects-container");
  const selector = document.getElementById("view-selector");
  const options = selector?.querySelectorAll(".view-option");

  const VIEW_KEY = "projects-view";

  function setView(view: "cards" | "grid") {
    if (!container || !options) return;
    container.setAttribute("data-view", view);
    options.forEach((btn) => {
      const isSelected = btn.getAttribute("data-view") === view;
      btn.setAttribute("aria-selected", String(isSelected));
      btn.classList.toggle("text-current/80", !isSelected);
    });
    try {
      localStorage.setItem(VIEW_KEY, view);
    } catch (_) {}
  }

  const saved = typeof localStorage !== "undefined" ? localStorage.getItem(VIEW_KEY) : null;
  if (saved === "grid" || saved === "cards") {
    setView(saved);
  }

  options?.forEach((btn) => {
    btn.addEventListener("click", () => {
      const view = btn.getAttribute("data-view") as "cards" | "grid";
      if (view) setView(view);
    });
  });
</script>
