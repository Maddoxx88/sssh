---
import { PAGE_THEMES } from "../lib/pageThemes";

const { text: workText, navPillText: workBg } = PAGE_THEMES.work;
const workElems = [
  {
    title: "itsrc @njit",
    role: "graduate research assistant",
    date: "may 2024 - present",
    desc: "cotributed to estip-app. worked on real-time mods and ui features. used by njtransit, njdot and other gov agencies",
    link: "https://njit.edu"
  },
  {
    title: "njit",
    role: "course development assistant",
    date: "jan 2024 - jul 2024",
    desc: "assisted in various tasks related to developing the CS670 (Artificial Intelligence) online course at njit",
    link: "https://njit.edu"
  },
  {
    title: "google developer group",
    role: "project supervisor (e-board)",
    date: "feb 2024 - present",
    desc: "lead and manage projects and technical workshops undertaken by gdg@njit",
    link: "https://dimension.dev"
  },
  {
    title: "mindcraft software",
    role: "full-stack dev",
    date: "may 2021 - jul 2023",
    desc: "lead frontend for kli (kotak life insruance) and implemented various security and devops features for vendors. also lead ci/cd migration in collaboration with cognizant team",
    link: "https://mindcraft.in/"
  },
  {
    title: "aryagreen infotech",
    role: "software consultant",
    date: "jun 2019 - nov 2020",
    desc: "implemented a search engine containing medical reposity worth 2M+ clinical trial records. worked on quick search and indexing.",
    link: "https://infotech.aryagreen.in/"
  }
]

---

<section class="mb-16 animate-fade-in-up">
  <h2 class="text-2xl font-bold mb-6 flex items-center font-inter" style={`color: ${workText}`}>
    <span class="mr-1">|</span>
    work
  </h2>

  <div class="space-y-8 font-inter">

    {workElems.map((work) => {
      return (
        <div class="work-card group rounded transition-all duration-100 p-3" style={`--work-text: ${workText}; --work-bg: ${workBg}`}>
          <a target="_blank" href={work.link} class="block">
            <h3 class="text-xl font-semibold mb-1 transition-colors duration-300 work-card-title">
              {work.title}
            </h3>
            <p class="text-sm mb-2 transition-colors duration-300 work-card-muted">
              {work.role} ({work.date})
            </p>
            <p class="text-sm transition-colors duration-300 work-card-muted">
              {work.desc}
            </p>
          </a>
        </div>
      )
    })}

  </div>
</section>

<style>
  .work-card .work-card-title {
    color: var(--work-text);
  }
  .work-card .work-card-muted {
    color: var(--work-text);
  }
  .work-card .work-card-muted:first-of-type {
    opacity: 0.7;
  }
  .work-card .work-card-muted:last-of-type {
    opacity: 0.6;
  }
  .work-card:hover {
    background: var(--work-text);
  }
  .work-card:hover .work-card-title,
  .work-card:hover .work-card-muted {
    color: var(--work-bg);
    opacity: 1;
  }
</style>