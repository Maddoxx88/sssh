---
import { Menu, X } from "lucide-react";
import { Image } from 'astro:assets';
import sunitHeaderOfficial from '../assets/sunit-official.png';
---

<nav class="relative flex items-center justify-between mb-14 text-sm">
  <!-- Desktop Navigation Links (hidden on mobile) -->
  <div class="hidden lg:flex items-center gap-1 font-mono">
    <a
      class={`px-4 py-2 rounded-full text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname === "/" ? "bg-[#FF4A00] text-white font-semibold" : "text-white/80 hover:text-white hover:bg-white/10"}`}
      href="/">[h] home</a>
    <a
      class={`px-4 py-2 rounded-full text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname.startsWith("/hackathons") ? "bg-[#FF4A00] text-white font-semibold" : "text-white/80 hover:text-white hover:bg-white/10"}`}
      href="/hackathons">[k] hackathons</a>
    <a
      class={`px-4 py-2 rounded-full text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname.startsWith("/work") ? "bg-[#FF4A00] text-white font-semibold" : "text-white/80 hover:text-white hover:bg-white/10"}`}
      href="/work">[w] work</a>
    <a
      class={`px-4 py-2 rounded-full text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname.startsWith("/blog") ? "bg-[#FF4A00] text-white font-semibold" : "text-white/80 hover:text-white hover:bg-white/10"}`}
      href="/blog">[b] blog</a>
    <a
      class={`px-4 py-2 rounded-full text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname.startsWith("/projects") ? "bg-[#FF4A00] text-white font-semibold" : "text-white/80 hover:text-white hover:bg-white/10"}`}
      href="/projects">[p] projects</a>
  </div>

    <!-- Hamburger Menu Icon -->
    <button id="hamburger-menu" class="lg:hidden p-2">
      <Menu id="hamburger" className="w-12 h-12"/>
      <X id="close-icon" className="hidden w-12 h-12" />
    </button>
  
    <!-- Hamburger Menu Icon -->
    <button id="hamburger-menu" class="lg:hidden p-2">
      <div class="flex">
        <!-- <Image src={sunitHeaderOfficial2} alt="Sunit Shirke" class="w-36 h-36 rounded-full p-1 shadow-lg bg-gradient-to-r from-[#833ab4] via-[#fd1d1d] to-[#fcb045]" /> -->
        <Image src={sunitHeaderOfficial} alt="Sunit Shirke" class="w-14 h-14 rounded-full shadow-lg" />
      </div>
    </button>

  <!-- Mobile Menu Links (hidden by default) -->
  <div
    id="mobileMenu"
    class="lg:hidden hidden absolute top-full left-0 right-0 mt-2 rounded-2xl bg-[#252525] border border-white/10 text-white shadow-xl shadow-black/20 z-10 font-mono overflow-hidden"
  >
    <a class={`block px-5 py-3.5 text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname === "/" ? "bg-[#FF4A00]/20 text-white font-semibold" : "hover:bg-white/5"}`} href="/">[h] home</a>
    <a class={`block px-5 py-3.5 text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname.startsWith("/work") ? "bg-[#FF4A00]/20 text-white font-semibold" : "hover:bg-white/5"}`} href="/work">[w] work</a>
    <a class={`block px-5 py-3.5 text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname.startsWith("/hackathons") ? "bg-[#FF4A00]/20 text-white font-semibold" : "hover:bg-white/5"}`} href="/hackathons">[k] hackathons</a>
    <a class={`block px-5 py-3.5 text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname.startsWith("/blog") ? "bg-[#FF4A00]/20 text-white font-semibold" : "hover:bg-white/5"}`} href="/blog">[b] blog</a>
    <a class={`block px-5 py-3.5 text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname.startsWith("/projects") ? "bg-[#FF4A00]/20 text-white font-semibold" : "hover:bg-white/5"}`} href="/projects">[p] projects</a>
  </div>
</nav>

<script>
  // Toggle the mobile menu when the hamburger button is clicked
  const hamburgerMenu = document.getElementById("hamburger-menu");
  const hamburger = document.getElementById("hamburger");
  const mobileMenu = document.getElementById("mobileMenu");
  const closeMenu = document.getElementById("close-icon");

  hamburgerMenu?.addEventListener("click", () => {
    hamburger?.classList.toggle("hidden");
    mobileMenu?.classList.toggle("hidden");
    closeMenu?.classList.toggle("hidden");
  });
</script>
