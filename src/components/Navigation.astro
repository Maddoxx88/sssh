---
import { Menu, X } from "lucide-react";
import { Image } from 'astro:assets';
import sunitHeaderOfficial from '../assets/sunit-official.png';

interface Props {
  textColor?: string;
  accentColor?: string;
  /** Color of text on the active nav pill (from page theme). */
  navPillTextColor?: string;
  /** Background of mobile dropdown when using custom theme. */
  dropdownBg?: string;
}

const { textColor, accentColor, navPillTextColor, dropdownBg } = Astro.props;
const hasCustom = textColor && accentColor;
const pillColor = navPillTextColor ?? accentColor;
---

<nav class="relative flex items-center justify-between mb-14 text-sm">
  <!-- Desktop Navigation Links (hidden on mobile) -->
  <div class="hidden lg:flex items-center gap-1 font-mono">
    <a
      class={`px-4 py-2 rounded-full text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname === "/" ? (hasCustom ? "font-semibold" : "bg-[#FF4A00] text-white font-semibold") : (hasCustom ? "opacity-70 hover:opacity-100" : "text-white/80 hover:text-white hover:bg-white/10")}`}
      style={hasCustom && Astro.url.pathname === "/" ? `background: ${accentColor}; color: ${pillColor};` : undefined}
      href="/">[h] home</a>
    <a
      class={`px-4 py-2 rounded-full text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname.startsWith("/hackathons") ? (hasCustom ? "font-semibold" : "bg-[#FF4A00] text-white font-semibold") : (hasCustom ? "opacity-70 hover:opacity-100" : "text-white/80 hover:text-white hover:bg-white/10")}`}
      style={hasCustom && Astro.url.pathname.startsWith("/hackathons") ? `background: ${accentColor}; color: ${pillColor};` : undefined}
      href="/hackathons">[k] hackathons</a>
    <a
      class={`px-4 py-2 rounded-full text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname.startsWith("/work") ? (hasCustom ? "font-semibold" : "bg-[#FF4A00] text-white font-semibold") : (hasCustom ? "opacity-70 hover:opacity-100" : "text-white/80 hover:text-white hover:bg-white/10")}`}
      style={hasCustom && Astro.url.pathname.startsWith("/work") ? `background: ${accentColor}; color: ${pillColor};` : undefined}
      href="/work">[w] work</a>
    <a
      class={`px-4 py-2 rounded-full text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname.startsWith("/blog") ? (hasCustom ? "font-semibold" : "bg-[#FF4A00] text-white font-semibold") : (hasCustom ? "opacity-70 hover:opacity-100" : "text-white/80 hover:text-white hover:bg-white/10")}`}
      style={hasCustom && Astro.url.pathname.startsWith("/blog") ? `background: ${accentColor}; color: ${pillColor};` : undefined}
      href="/blog">[b] blog</a>
    <a
      class={`px-4 py-2 rounded-full text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname.startsWith("/projects") ? (hasCustom ? "font-semibold" : "bg-[#FF4A00] text-white font-semibold") : (hasCustom ? "opacity-70 hover:opacity-100" : "text-white/80 hover:text-white hover:bg-white/10")}`}
      style={hasCustom && Astro.url.pathname.startsWith("/projects") ? `background: ${accentColor}; color: ${pillColor};` : undefined}
      href="/projects">[p] projects</a>
  </div>

    <!-- Hamburger Menu Icon -->
    <button id="hamburger-menu" class="lg:hidden p-2">
      <Menu id="hamburger" className="w-12 h-12"/>
      <X id="close-icon" className="hidden w-12 h-12" />
    </button>
  
    <!-- Hamburger Menu Icon -->
    <button id="hamburger-menu" class="lg:hidden p-2">
      <div class="flex">
        <!-- <Image src={sunitHeaderOfficial2} alt="Sunit Shirke" class="w-36 h-36 rounded-full p-1 shadow-lg bg-gradient-to-r from-[#833ab4] via-[#fd1d1d] to-[#fcb045]" /> -->
        <Image src={sunitHeaderOfficial} alt="Sunit Shirke" class="w-14 h-14 rounded-full shadow-lg" />
      </div>
    </button>

  <!-- Mobile Menu Links (hidden by default) -->
  <div
    id="mobileMenu"
    class={`lg:hidden hidden absolute top-full left-0 right-0 mt-2 rounded-2xl shadow-xl z-10 font-mono overflow-hidden ${hasCustom ? 'border border-white/20' : 'bg-[#252525] border border-white/10 text-white shadow-black/20'}`}
    style={hasCustom && dropdownBg ? `background: ${dropdownBg}; color: ${accentColor};` : undefined}
  >
    <a class={`block px-5 py-3.5 text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname === "/" ? (hasCustom ? "font-semibold opacity-100" : "bg-[#FF4A00]/20 text-white font-semibold") : (hasCustom ? "opacity-70 hover:opacity-100" : "hover:bg-white/5")}`} style={hasCustom && Astro.url.pathname === "/" ? `background: ${accentColor}20;` : undefined} href="/">[h] home</a>
    <a class={`block px-5 py-3.5 text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname.startsWith("/work") ? (hasCustom ? "font-semibold opacity-100" : "bg-[#FF4A00]/20 text-white font-semibold") : (hasCustom ? "opacity-70 hover:opacity-100" : "hover:bg-white/5")}`} style={hasCustom && Astro.url.pathname.startsWith("/work") ? `background: ${accentColor}20;` : undefined} href="/work">[w] work</a>
    <a class={`block px-5 py-3.5 text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname.startsWith("/hackathons") ? (hasCustom ? "font-semibold opacity-100" : "bg-[#FF4A00]/20 text-white font-semibold") : (hasCustom ? "opacity-70 hover:opacity-100" : "hover:bg-white/5")}`} style={hasCustom && Astro.url.pathname.startsWith("/hackathons") ? `background: ${accentColor}20;` : undefined} href="/hackathons">[k] hackathons</a>
    <a class={`block px-5 py-3.5 text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname.startsWith("/blog") ? (hasCustom ? "font-semibold opacity-100" : "bg-[#FF4A00]/20 text-white font-semibold") : (hasCustom ? "opacity-70 hover:opacity-100" : "hover:bg-white/5")}`} style={hasCustom && Astro.url.pathname.startsWith("/blog") ? `background: ${accentColor}20;` : undefined} href="/blog">[b] blog</a>
    <a class={`block px-5 py-3.5 text-[15px] transition-all duration-300 ease-out ${Astro.url.pathname.startsWith("/projects") ? (hasCustom ? "font-semibold opacity-100" : "bg-[#FF4A00]/20 text-white font-semibold") : (hasCustom ? "opacity-70 hover:opacity-100" : "hover:bg-white/5")}`} style={hasCustom && Astro.url.pathname.startsWith("/projects") ? `background: ${accentColor}20;` : undefined} href="/projects">[p] projects</a>
  </div>
</nav>

<script>
  // Toggle the mobile menu when the hamburger button is clicked
  const hamburgerMenu = document.getElementById("hamburger-menu");
  const hamburger = document.getElementById("hamburger");
  const mobileMenu = document.getElementById("mobileMenu");
  const closeMenu = document.getElementById("close-icon");

  hamburgerMenu?.addEventListener("click", () => {
    hamburger?.classList.toggle("hidden");
    mobileMenu?.classList.toggle("hidden");
    closeMenu?.classList.toggle("hidden");
  });
</script>